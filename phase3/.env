# ============================================
# 🐳 PHASE 3 - DOCKER CONTAINER ENVIRONMENT
# ============================================
# File mẫu cho triển khai với Docker Compose
# Copy sang .env và điền giá trị thật
# ============================================

# -----------------------------
# APPLICATION CONFIGURATION
# -----------------------------
PORT=3000
NODE_ENV=production

# -----------------------------
# MONGODB CONTAINER CONFIGURATION
# -----------------------------
MONGO_INITDB_DATABASE=products_db
MONGO_INITDB_ROOT_USERNAME=zuinq
MONGO_INITDB_ROOT_PASSWORD=256831quynh

# -----------------------------
# CONNECTION STRING
# -----------------------------
MONGO_URI=mongodb://${MONGO_INITDB_ROOT_USERNAME}:${MONGO_INITDB_ROOT_PASSWORD}@mongodb:27017/${MONGO_INITDB_DATABASE}?authSource=admin

# -----------------------------
# DOCKER IMAGE CONFIGURATION
# -----------------------------
IMAGE_NAME=yourusername/devops-app
IMAGE_TAG=latest

# -----------------------------
# PORT MAPPING
# -----------------------------
HOST_PORT=3000
# HOST_PORT=3001  # Dùng nếu Phase 2 đang chạy ở port 3000

# -----------------------------
# FILE UPLOAD
# -----------------------------
UPLOAD_PATH=/app/public/uploads
MAX_FILE_SIZE=10485760

# -----------------------------
# VOLUMES
# -----------------------------
MONGO_VOLUME=mongodb_data
UPLOADS_VOLUME=uploads
