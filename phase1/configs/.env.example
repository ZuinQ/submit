# ============================================
# 📦 PHASE 1 - DEVELOPMENT ENVIRONMENT
# ============================================
# File mẫu cho biến môi trường - Copy sang .env và điền giá trị thật
# ============================================

# -----------------------------
# SERVER CONFIGURATION
# -----------------------------
# Cổng chạy ứng dụng (mặc định: 3000)
PORT=3000

# Môi trường: development, production, test
NODE_ENV=development

# -----------------------------
# DATABASE CONFIGURATION (MongoDB)
# -----------------------------
# Kết nối MongoDB local (dùng cho development)
MONGO_URI=mongodb://localhost:27017/products_db

# Nếu dùng MongoDB Atlas (cloud), sử dụng định dạng:
# MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/products_db?retryWrites=true&w=majority

# -----------------------------
# FILE UPLOAD CONFIGURATION
# -----------------------------
# Thư mục lưu file upload (relative path)
UPLOAD_DIR=./public/uploads

# Kích thước file tối đa (bytes) - 5MB
MAX_FILE_SIZE=5242880

# -----------------------------
# SESSION CONFIGURATION (nếu có)
# -----------------------------
# Secret key cho session (thay bằng giá trị ngẫu nhiên khi dùng thật)
SESSION_SECRET=your-session-secret-key-here

# -----------------------------
# LOGGING
# -----------------------------
# Mức độ log: debug, info, warn, error
LOG_LEVEL=debug

# ============================================
# 📝 HƯỚNG DẪN SỬ DỤNG:
# 1. Copy file: cp .env.example .env
# 2. Sửa các giá trị phù hợp với môi trường của bạn
# 3. KHÔNG bao giờ commit file .env thật lên GitHub!
# ============================================